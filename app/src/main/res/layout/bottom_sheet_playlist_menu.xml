<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bottom_sheet_playlists_bg"
    android:orientation="vertical"
    android:paddingBottom="@dimen/margin_16">

    <View
        android:layout_width="@dimen/bottom_sheet_handle_width"
        android:layout_height="@dimen/bottom_sheet_handle_height"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="@dimen/margin_8"
        android:background="@drawable/bg_bottom_sheet_handle" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/margin_16"
        android:layout_marginTop="@dimen/margin_16"
        android:layout_marginEnd="@dimen/margin_16"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <ImageView
            android:id="@+id/menu_playlist_cover"
            android:layout_width="@dimen/playlist_picker_row_cover_size"
            android:layout_height="@dimen/playlist_picker_row_cover_size"
            android:scaleType="centerCrop"
            android:src="@drawable/playlist_grid_cover_placeholder" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/margin_8"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/menu_playlist_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:maxLines="1"
                android:textColor="@color/text_color_primary"
                android:textSize="@dimen/text_size_16" />

            <TextView
                android:id="@+id/menu_playlist_count"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/margin_4"
                android:textColor="@color/search_result_artist_text_color"
                android:textSize="@dimen/text_size_11" />
        </LinearLayout>
    </LinearLayout>

    <TextView
        android:id="@+id/menu_action_share"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/margin_16"
        android:background="?attr/selectableItemBackground"
        android:paddingHorizontal="@dimen/margin_16"
        android:paddingVertical="@dimen/padding_12"
        android:text="@string/playlist_menu_share"
        android:textColor="@color/text_color_primary"
        android:textSize="@dimen/text_size_16" />

    <TextView
        android:id="@+id/menu_action_edit"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="?attr/selectableItemBackground"
        android:paddingHorizontal="@dimen/margin_16"
        android:paddingVertical="@dimen/padding_12"
        android:text="@string/playlist_menu_edit"
        android:textColor="@color/text_color_primary"
        android:textSize="@dimen/text_size_16" />

    <TextView
        android:id="@+id/menu_action_delete"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="?attr/selectableItemBackground"
        android:paddingHorizontal="@dimen/margin_16"
        android:paddingVertical="@dimen/padding_12"
        android:text="@string/playlist_menu_delete"
        android:textColor="@color/text_color_primary"
        android:textSize="@dimen/text_size_16" />

</LinearLayout>
