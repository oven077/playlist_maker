<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/screen_background"
    android:orientation="vertical">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/playlist_detail_toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        app:navigationIcon="@drawable/arrow_back"
        app:navigationIconTint="@color/toolbar_color"
        app:titleTextAppearance="@style/NewPlaylistToolbarTitle"
        app:titleTextColor="@color/toolbar_color"
        tools:title="Плейлист" />

    <com.google.android.material.imageview.ShapeableImageView
        android:id="@+id/playlist_detail_cover"
        android:layout_width="match_parent"
        android:layout_height="@dimen/playlist_detail_cover_height"
        android:layout_marginHorizontal="@dimen/padding_16"
        android:layout_marginTop="@dimen/margin_8"
        android:contentDescription="@string/playlist_cover_preview_description"
        android:scaleType="centerCrop"
        app:shapeAppearanceOverlay="@style/ShapeAppearanceOverlay.PlaylistGridCoverTop"
        tools:src="@drawable/playlist_grid_cover_placeholder" />

    <TextView
        android:id="@+id/playlist_detail_name"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="@dimen/padding_16"
        android:layout_marginTop="@dimen/margin_16"
        android:ellipsize="end"
        android:fontFamily="@font/ys_display_medium"
        android:maxLines="2"
        android:textColor="@color/text_color_primary"
        android:textFontWeight="500"
        android:textSize="@dimen/text_size_22"
        tools:text="Плейлист" />

    <TextView
        android:id="@+id/playlist_detail_description"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="@dimen/padding_16"
        android:layout_marginTop="@dimen/margin_8"
        android:fontFamily="@font/ys_text_regular"
        android:textColor="@color/text_color_primary"
        android:textSize="@dimen/text_size_14"
        android:visibility="gone"
        tools:text="Описание"
        tools:visibility="visible" />

    <LinearLayout
        android:id="@+id/playlist_detail_meta_row"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="@dimen/padding_16"
        android:layout_marginTop="@dimen/margin_8"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/playlist_detail_meta_duration"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/ys_text_regular"
            android:textColor="@color/search_result_artist_text_color"
            android:textSize="@dimen/text_size_11"
            tools:text="0 минут" />

        <ImageView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingHorizontal="@dimen/padding_4"
            android:paddingVertical="@dimen/padding_4"
            android:src="@drawable/ellipse" />

        <TextView
            android:id="@+id/playlist_detail_meta_track_count"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/ys_text_regular"
            android:textColor="@color/search_result_artist_text_color"
            android:textSize="@dimen/text_size_11"
            tools:text="0 треков" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/playlist_detail_actions"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="@dimen/padding_16"
        android:layout_marginTop="@dimen/margin_16"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <ImageView
            android:id="@+id/playlist_detail_share"
            android:layout_width="@dimen/icon_size_24"
            android:layout_height="@dimen/icon_size_24"
            android:contentDescription="@string/playlist_detail_share"
            android:foreground="?attr/selectableItemBackgroundBorderless"
            android:padding="@dimen/padding_4"
            android:src="@drawable/share"
            app:tint="@color/toolbar_color" />

        <ImageView
            android:id="@+id/playlist_detail_more"
            android:layout_width="@dimen/icon_size_24"
            android:layout_height="@dimen/icon_size_24"
            android:layout_marginStart="@dimen/margin_16"
            android:contentDescription="@string/playlist_detail_more"
            android:foreground="?attr/selectableItemBackgroundBorderless"
            android:padding="@dimen/padding_4"
            android:src="@drawable/more_horiz"
            app:tint="@color/toolbar_color" />
    </LinearLayout>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="@dimen/margin_24"
        android:layout_weight="1"
        android:background="@drawable/bottom_sheet_playlists_bg">

        <View
            android:layout_width="@dimen/bottom_sheet_handle_width"
            android:layout_height="@dimen/bottom_sheet_handle_height"
            android:layout_gravity="top|center_horizontal"
            android:layout_marginTop="@dimen/margin_8"
            android:background="@drawable/bg_bottom_sheet_handle" />

        <LinearLayout
            android:id="@+id/playlist_detail_placeholder"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="56dp"
            android:gravity="center"
            android:orientation="vertical"
            android:visibility="gone">

            <ImageView
                android:layout_width="@dimen/placeholder_icon_size"
                android:layout_height="@dimen/placeholder_icon_size"
                android:contentDescription="@string/playlist_empty_tracks"
                android:src="@drawable/nothingfound" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:fontFamily="@font/ys_display_medium"
                android:text="@string/playlist_empty_tracks"
                android:textAlignment="center"
                android:textColor="@color/text_color_primary"
                android:textFontWeight="500"
                android:textSize="@dimen/text_size_19" />
        </LinearLayout>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/playlist_detail_tracks"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:paddingTop="@dimen/margin_24"
            android:paddingBottom="@dimen/padding_16"
            android:paddingHorizontal="@dimen/padding_16"
            android:visibility="gone"
            tools:listitem="@layout/item_search_recycler" />
    </FrameLayout>

</LinearLayout>
